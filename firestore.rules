rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: incidents
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required, immutable) - The UID of the user
    //   - input: string (required) - Original input
    //   - response: map (required) - AI protocol
    //   - location: map (optional) - User coordinates
    //   - timestamp: timestamp (required) - Creation time
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function isValidIncident(data) {
      let allowedFields = ['uid', 'input', 'response', 'timestamp', 'location'];
      let requiredFields = ['uid', 'input', 'response', 'timestamp'];
      
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(allowedFields) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.input is string && data.input.size() > 0 && data.input.size() < 5000 &&
             data.response is map && data.response.size() < 20 &&
             (!('location' in data) || (data.location is map && data.location.size() < 10)) &&
             data.timestamp is timestamp && data.timestamp <= request.time;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /incidents/{incidentId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && isValidIncident(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false; // Incidents are immutable history
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
