{
  "entities": {
    "Incident": {
      "title": "Incident",
      "description": "A recorded emergency incident and its AI-generated protocol.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The UID of the user who created the incident. Must match auth.uid."
        },
        "input": {
          "type": "string",
          "description": "The original user input describing the emergency. Max 5000 characters."
        },
        "response": {
          "type": "object",
          "description": "The AI-generated emergency response protocol. Contains type, riskLevel, actions, precautions, summary, and searchQuery."
        },
        "location": {
          "type": "object",
          "description": "User's coordinates at the time of incident. Contains lat and lng numbers."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the incident was recorded. Must be recent."
        }
      },
      "required": ["uid", "input", "response", "timestamp"]
    },
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The UID of the user. Matches auth.uid."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's email address."
        },
        "displayName": {
          "type": "string",
          "description": "User's display name. Max 100 characters."
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "URL to user's profile picture."
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin"],
          "description": "User's role in the application."
        }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "incidents": {
      "schema": "Incident",
      "description": "Collection of emergency incidents."
    },
    "users": {
      "schema": "User",
      "description": "Collection of user profiles."
    }
  }
}
